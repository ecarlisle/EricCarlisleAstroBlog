---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import SocialLinks from './SocialLinks.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header id="site-header" class="site-header site-frame">
  <div class="header-inner">
    <nav aria-label="Main navigation">
      <a href="/" class="site-title">{SITE_TITLE.toLowerCase()}</a>
      <div class="internal-links">
        <HeaderLink href="/">Home</HeaderLink>
        <HeaderLink href="/blog">Blog</HeaderLink>
        <HeaderLink href="/about">About</HeaderLink>
        <HeaderLink href="/contact">Contact</HeaderLink>
      </div>
    </nav>
    <div class="nav-controls">
        <pagefind-modal-trigger></pagefind-modal-trigger>
        <ThemeToggle />
      <button class="hamburger" id="hamburger-btn" aria-controls="mobile-nav" aria-expanded="false" aria-label="Menu" type="button">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
      <span class="nav-divider" aria-hidden="true"></span>
      <div class="social-links">
        <SocialLinks />
      </div>
    </div>
  </div>
  <div id="mobile-nav" class="mobile-nav" role="navigation" aria-label="Mobile navigation" inert>
    <HeaderLink href="/">Home</HeaderLink>
    <HeaderLink href="/blog">Blog</HeaderLink>
    <HeaderLink href="/about">About</HeaderLink>
    <HeaderLink href="/contact">Contact</HeaderLink>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: oklch(from var(--bg-main) l c h / 0.85);
    border-bottom: 1px solid var(--border-muted);
    will-change: transform;
    transition: transform var(--transition-normal);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  @supports not (backdrop-filter: blur(1px)) {
    .site-header {
      background: var(--bg-surface);
    }
  }

  .site-header.header--hidden {
    transform: translateY(-100%);
  }


  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  nav {
    display: flex;
    align-items: center;
    gap: var(--space-component);
  }

  h2 {
    margin: 0;
  }

  .site-title {
    text-decoration: none;
    font-family: var(--font-headers);
    font-weight: 700;
    font-size: var(--type-size-h2);
    color: var(--brand-primary);
    transition: color var(--transition-fast);
  }

  .site-title:hover {
    color: var(--brand-accent);
  }

  .nav-controls {
    display: flex;
    align-items: center;
    gap: var(--space-inline);
  }

  .nav-divider {
    display: block;
    width: 1px;
    height: 24px;
    background: var(--border-muted);
  }

  .social-links {
    display: flex;
    gap: var(--space-inline);
  }

  .social-links :global(a) {
    display: inline-flex;
    align-items: center;
    color: var(--text-secondary);
    transition: color var(--transition-fast);
  }

  .social-links :global(a:hover) {
    color: var(--brand-primary);
  }

  .hamburger {
    display: none;
    position: relative;
    z-index: 110;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: var(--size-touch-target-min);
    height: var(--size-touch-target-min);
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    color: var(--text-primary);
    -webkit-tap-highlight-color: transparent;
  }

  .hamburger-line {
    display: block;
    width: 22px;
    height: 2px;
    background: currentColor;
    border-radius: 1px;
    transition: transform var(--transition-normal), opacity var(--transition-normal);
    transform-origin: center;
  }

  .hamburger.is-open .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .hamburger.is-open .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .hamburger.is-open .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .mobile-nav {
    position: fixed;
    top: var(--header-height);
    right: 0;
    bottom: 0;
    left: 0;
    min-height: calc(100vh - var(--header-height));
    z-index: 105;
    display: flex;
    flex-direction: column;
    gap: var(--space-component);
    padding: var(--space-section) var(--space-sm);
    background: oklch(from var(--bg-main) l c h / 0.98);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--transition-normal), visibility var(--transition-normal);
    overflow-y: auto;
  }

  @supports not (backdrop-filter: blur(1px)) {
    .mobile-nav {
      background: var(--bg-surface);
    }
  }

  .mobile-nav.is-open {
    opacity: 1;
    visibility: visible;
  }

  .mobile-nav :global(a) {
    font-size: var(--type-size-h3);
    font-weight: 500;
    padding: var(--space-inline) 0;
    border-bottom: 1px solid var(--border-muted);
    color: var(--text-primary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .mobile-nav :global(a:hover),
  .mobile-nav :global(a.active) {
    color: var(--brand-primary);
  }

  .mobile-nav :global(a.active) {
    font-weight: 700;
  }

  @media (max-width: 840px) {
    .internal-links {
      display: none;
    }

    .hamburger {
      display: flex;
    }

    .social-links {
      display: none;
    }

    .nav-divider {
      display: none;
    }

    .nav-controls {
      gap: 2px;
    }

    .site-header {
      border-bottom-color: var(--border-main);
    }
  }
</style>

<style is:global>
  body {
    padding-top: var(--header-height, 4.5rem);
  }
</style>

<script>
  const header = document.getElementById('site-header') as HTMLElement;

  function syncHeaderHeight(): void {
    document.documentElement.style.setProperty(
      '--header-height',
      `${header.offsetHeight}px`,
    );
  }

  syncHeaderHeight();
  new ResizeObserver(syncHeaderHeight).observe(header);

  let lastScrollY: number = window.scrollY;
  let rafPending: boolean = false;

  function updateHeaderVisibility(): void {
    const currentScrollY = window.scrollY;

    if (currentScrollY <= 0) {
      header.classList.remove('header--hidden');
    } else if (currentScrollY > lastScrollY) {
      header.classList.add('header--hidden');
    } else {
      header.classList.remove('header--hidden');
    }

    lastScrollY = currentScrollY;
    rafPending = false;
  }

  window.addEventListener(
    'scroll',
    () => {
      if (!rafPending) {
        rafPending = true;
        window.requestAnimationFrame(updateHeaderVisibility);
      }
    },
    { passive: true },
  );

  header.addEventListener('focusin', () => {
    header.classList.remove('header--hidden');
  });

  const hamburgerBtn = document.getElementById('hamburger-btn') as HTMLButtonElement;
  const mobileNav = document.getElementById('mobile-nav') as HTMLElement;

  if (hamburgerBtn && mobileNav) {
    let previousFocus: HTMLElement | null = null;

    function openMobileNav(): void {
      hamburgerBtn.classList.add('is-open');
      mobileNav.classList.add('is-open');
      mobileNav.removeAttribute('inert');
      hamburgerBtn.setAttribute('aria-expanded', 'true');
      previousFocus = document.activeElement as HTMLElement | null;
      const firstLink = mobileNav.querySelector('a');
      firstLink?.focus();
      document.body.style.overflow = 'hidden';
    }

    function closeMobileNav(): void {
      hamburgerBtn.classList.remove('is-open');
      mobileNav.classList.remove('is-open');
      mobileNav.setAttribute('inert', '');
      hamburgerBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      previousFocus?.focus();
      previousFocus = null;
    }

    function isMobileNavOpen(): boolean {
      return mobileNav.classList.contains('is-open');
    }

    hamburgerBtn.addEventListener('click', () => {
      if (isMobileNavOpen()) {
        closeMobileNav();
      } else {
        openMobileNav();
      }
    });

    mobileNav.addEventListener('click', (e: MouseEvent) => {
      const target = e.target as HTMLElement;
      if (target.closest('a')) {
        closeMobileNav();
      }
    });

    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape' && isMobileNavOpen()) {
        closeMobileNav();
        e.preventDefault();
      }
    });

    const desktopMql = window.matchMedia('(min-width: 721px)');
    desktopMql.addEventListener('change', () => {
      if (desktopMql.matches && isMobileNavOpen()) {
        closeMobileNav();
      }
    });
  }
</script>
