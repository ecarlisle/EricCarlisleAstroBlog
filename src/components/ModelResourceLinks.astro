<style>
  .model-resource-links {
    display: grid;
    gap: var(--space-xs);
    padding: 0;
    margin: 0 0 var(--space-component);
    list-style: none;
  }

  .model-resource-links li {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    margin: 0;
  }

  .model-resource-links svg {
    flex: 0 0 auto;
  }
</style>
