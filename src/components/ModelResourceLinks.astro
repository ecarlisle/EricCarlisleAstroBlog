      <path
        d="M11.955.005C5.425-.152-.091 5.485.007 11.805-.228 18.56 5.544 24.055 12.06 24c6.562-.1 11.853-5.405 11.941-11.97.031-6.547-5.495-12.21-12.045-12.025Zm-.047 1.701a10.276 10.276 0 1 1-.001 20.553 10.276 10.276 0 0 1 .001-20.553ZM6.358 6.487c-.322 0-.358.033-.358.361v2.248c0 .351.04.391.398.391h3.823c.274 0 .274.004.274.265v9.736c0 .12.078.2.2.199h2.554c.247-.003.283-.035.283-.28v-9.32c0-.124.004-.239 0-.39s.055-.21.218-.21h3.9c.319.004.35-.032.35-.344V6.855c0-.34-.024-.363-.37-.363l-5.625-.005H6.358Z"
