---
import Layout from '../layouts/BlogPost.astro';
---

<Layout
  title="Search"
  description="Find articles, portfolio notes, and other site pages."
  pageType="about"
>
  <p>
    Find articles, portfolio notes, and other site pages.
  </p>
  <div id="search-ui" data-pagefind-ignore="all">
    <pagefind-search></pagefind-search>
  </div>
</Layout>

<style>
  #search-ui {
    margin-top: var(--space-component-lg);
  }

  #search-ui :global(pagefind-search) {
    display: block;
  }
</style>
