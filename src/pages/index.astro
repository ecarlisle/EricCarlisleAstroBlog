---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '@components/BaseHead.astro';
import Card from '@components/Card.astro';
import Footer from '@components/Footer.astro';
import Header from '@components/Header.astro';
import SocialLinks from '@components/SocialLinks.astro';
import { AUTHOR_NAME, AUTHOR_JOB_TITLE, GA_MEASUREMENT_ID, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const posts = allPosts.slice(0, 6);
const [featured] = allPosts;
const allTags = [...new Set(allPosts.flatMap((p) => p.data.tags ?? []))].sort();
const featuredWordCount =
  featured.body
    ?.replace(/^---[\s\S]*?---/, '')
    .replace(/<[^>]*>/g, '')
    .replace(/```[\s\S]*?```/g, '')
    .trim()
    .split(/\s+/)
    .filter(Boolean).length ?? 0;

const totalWords = allPosts.reduce((sum, p) => {
  const count =
    p.body
      ?.replace(/^---[\s\S]*?---/, '')
      .replace(/<[^>]*>/g, '')
      .replace(/```[\s\S]*?```/g, '')
      .trim()
      .split(/\s+/)
      .filter(Boolean).length ?? 0;
  return sum + count;
}, 0);
const totalWordsK = totalWords >= 1000 ? `${(totalWords / 1000).toFixed(0)}K` : `${totalWords}`;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} pageType="homepage" />

    <script
      type="text/partytown"
      src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}
    ></script>
    <script type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', GA_MEASUREMENT_ID);
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main-content" tabindex="-1">
      <section class="hero-section">
        <div class="hero-intro">
          <div class="hero-avatar" aria-hidden="true">
            <svg viewBox="0 0 80 80" width="80" height="80">
              <rect width="80" height="80" rx="40" fill="oklch(0.2 0.025 280)" />
              <text x="40" y="46" text-anchor="middle" font-family="Plus Jakarta Sans Variable, system-ui, sans-serif" font-size="28" font-weight="700" fill="oklch(0.95 0.008 280)">EC</text>
            </svg>
          </div>
          <div class="hero-text">
            <p class="hero-tagline">{AUTHOR_JOB_TITLE}</p>
            <h1>{SITE_TITLE}</h1>
            <p>{SITE_DESCRIPTION}</p>
            <p class="hero-status">// {allPosts.length} POSTS · ~{totalWordsK} WORDS · EST. 2022</p>
          </div>
        </div>

        <div class="featured-post">
          <p class="featured-post-label">Latest post</p>
          <h2><a href={`/blog/${featured.id}/`}>{featured.data.title}</a></h2>
          <p>{featured.data.description}</p>
          <p class="meta">
            <time datetime={featured.data.pubDate.toISOString()}>
              {featured.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <span class="reading-time">{Math.ceil(featuredWordCount / 200)} min read</span>
          </p>
        </div>
      </section>

      <section class="feed">
        <header class="feed-header">
          <h2>All posts</h2>
          <p class="feed-description">Notes, ideas, experiments.</p>
        </header>

        {allTags.length > 0 && (
          <div class="filter-bar" role="group" aria-label="Filter posts by tag">
            <button class="active" data-tag="all">All</button>
            {allTags.map((tag) => (
              <button data-tag={tag}>{tag}</button>
            ))}
          </div>
        )}

        <ul class="grid grid--cards" id="post-grid">
          {posts.map((post, i) => {
            const wc =
              post.body
                ?.replace(/^---[\s\S]*?---/, '')
                .replace(/<[^>]*>/g, '')
                .replace(/```[\s\S]*?```/g, '')
                .trim()
                .split(/\s+/)
                .filter(Boolean).length ?? 0;
            return (
              <Card
                as="li"
                title={post.data.title}
                href={`/blog/${post.id}/`}
                author={AUTHOR_NAME}
                pubDate={post.data.pubDate}
                tags={post.data.tags}
                readingTime={wc}
                index={i}
              >
                {post.data.heroImage && (
                  <Image
                    slot="image"
                    src={post.data.heroImage}
                    alt={post.data.coverAlt || post.data.title}
                    width={720}
                    height={360}
                  />
                )}
                <p>{post.data.description}</p>
              </Card>
            );
          })}
        </ul>

        {allPosts.length > 6 && (
          <p style="text-align:center;margin-top:var(--space-section)">
            <a href="/blog" class="button">View all posts</a>
          </p>
        )}
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .feed-header {
    margin-bottom: var(--space-component-lg);
  }

  .feed-description {
    color: var(--text-secondary);
    margin-bottom: 0;
  }

  ul.grid {
    list-style: none;
    padding: 0;
    margin: 0;
  }
</style>

<script>
  const filterBar = document.querySelector('.filter-bar');
  if (filterBar) {
    const buttons = filterBar.querySelectorAll('button');
    const cards = document.querySelectorAll('#post-grid .card');

    function filterByTag(tag: string): void {
      buttons.forEach((b) => b.classList.toggle('active', b.getAttribute('data-tag') === tag));
      cards.forEach((card) => {
        const cardTags = card.getAttribute('data-tags');
        if (tag === 'all' || (cardTags && cardTags.includes(tag))) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => filterByTag(btn.getAttribute('data-tag')!));
    });

    const urlTag = new URLSearchParams(window.location.search).get('tag');
    if (urlTag && [...buttons].some((b) => b.getAttribute('data-tag') === urlTag)) {
      filterByTag(urlTag);
    }
  }
</script>
