---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '@components/BaseHead.astro';
import Card from '@components/Card.astro';
import Footer from '@components/Footer.astro';
import Header from '@components/Header.astro';
import PaginationNav from '@components/PaginationNav.astro';
import { AUTHOR_NAME, GA_MEASUREMENT_ID, SITE_TITLE } from '../consts';

const PAGE_SIZE = 10;

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const posts = allPosts.slice(0, PAGE_SIZE);
const allTags = [...new Set(allPosts.flatMap((p) => p.data.tags ?? []))].sort();
const totalPages = Math.ceil(allPosts.length / PAGE_SIZE);

const tagPages: Record<string, number[]> = {};
allPosts.forEach((post, i) => {
  const page = Math.floor(i / PAGE_SIZE) + 1;
  for (const tag of post.data.tags ?? []) {
    if (!tagPages[tag]) tagPages[tag] = [];
    if (!tagPages[tag].includes(page)) tagPages[tag].push(page);
  }
});
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Blog — ${SITE_TITLE}`} description="All blog posts" pageType="collection" />

    <script
      type="text/partytown"
      src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}
    ></script>
    <script type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', GA_MEASUREMENT_ID);
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main-content" tabindex="-1">
      <section class="feed">
        <header class="feed-header">
          <h1>Blog</h1>
          <p class="feed-description">All posts ({allPosts.length} total)</p>
        </header>

        {allTags.length > 0 && (
          <div class="filter-bar" role="group" aria-label="Filter posts by tag" data-tag-pages={JSON.stringify(tagPages)}>
            <a href="/blog" role="button">All</a>
            {allTags.map((tag) => (
              <a href={`/blog?tag=${tag}`} role="button">{tag}</a>
            ))}
          </div>
        )}

        <p id="no-results" class="callout" style="display:none">
          No posts tagged "<strong></strong>" on this page.
          {tagPages && Object.keys(tagPages).length > 0 && <span>Visit <span class="page-links"></span>.</span>}
        </p>

        <ul class="grid grid--cards" id="post-grid">
          {posts.map((post, i) => {
            const wc =
              post.body
                ?.replace(/^---[\s\S]*?---/, '')
                .replace(/<[^>]*>/g, '')
                .replace(/```[\s\S]*?```/g, '')
                .trim()
                .split(/\s+/)
                .filter(Boolean).length ?? 0;
            return (
              <Card
                as="li"
                title={post.data.title}
                href={`/blog/${post.id}/`}
                author={AUTHOR_NAME}
                pubDate={post.data.pubDate}
                tags={post.data.tags}
                readingTime={wc}
                index={i}
              >
                {post.data.heroImage && (
                  <Image
                    slot="image"
                    src={post.data.heroImage}
                    alt={post.data.coverAlt || post.data.title}
                    width={720}
                    height={360}
                  />
                )}
                <p>{post.data.description}</p>
              </Card>
            );
          })}
        </ul>

        {totalPages > 1 && (
          <PaginationNav next={{ url: '/blog/page/2', label: 'Next page →' }} />
        )}
      </section>
    </main>
    <Footer />
    <pagefind-modal></pagefind-modal>
  </body>
</html>

<style>
  .feed-header {
    margin-bottom: var(--space-component-lg);
  }

  .feed-description {
    color: var(--text-secondary);
    margin-bottom: 0;
  }

  ul.grid {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  #no-results {
    text-align: center;
    margin-bottom: var(--space-component);
  }
</style>

<script is:inline>
  const filterBar = document.querySelector('.filter-bar');
  if (filterBar) {
    const tagPagesData = JSON.parse(filterBar.dataset.tagPages);
    const links = filterBar.querySelectorAll('a');
    const cards = document.querySelectorAll('#post-grid .card');
    const noResults = document.getElementById('no-results');

    function filterByTag(tag) {
      links.forEach((a) => {
        const href = a.getAttribute('href');
        const isAll = href === '/blog';
        const isMatch = !isAll && href.includes(`?tag=${tag}`);
        a.classList.toggle('active', tag === 'all' ? isAll : isMatch);
      });

      let visibleCount = 0;
      cards.forEach((card) => {
        const cardTags = card.getAttribute('data-tags');
        if (tag === 'all' || (cardTags && cardTags.includes(tag))) {
          card.style.display = '';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });

      if (noResults) {
        if (tag !== 'all' && visibleCount === 0) {
          const nameEl = noResults.querySelector('strong');
          if (nameEl) nameEl.textContent = tag;
          const pageLinks = noResults.querySelector('.page-links');
          if (pageLinks) {
            const pages = tagPagesData[tag];
            if (pages && pages.length > 0) {
              pageLinks.innerHTML = pages
                .map((p) => `<a href="/blog/page/${p}?tag=${tag}">page ${p}</a>`)
                .join(', ');
            } else {
              pageLinks.innerHTML = '';
            }
          }
          noResults.style.display = '';
        } else {
          noResults.style.display = 'none';
        }
      }
    }

    links.forEach((a) => {
      a.addEventListener('click', (e) => {
        e.preventDefault();
        const url = new URL(a.href);
        const tag = url.searchParams.get('tag') || 'all';
        filterByTag(tag);
        window.history.replaceState(null, '', a.href);
      });
    });

    const urlTag = new URLSearchParams(window.location.search).get('tag');
    if (urlTag && [...links].some((a) => a.href.includes(`?tag=${urlTag}`))) {
      filterByTag(urlTag);
    }
  }
</script>
