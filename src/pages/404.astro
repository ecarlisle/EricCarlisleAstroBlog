---
import BaseHead from '@components/BaseHead.astro';
import Footer from '@components/Footer.astro';
import Header from '@components/Header.astro';
import { GA_MEASUREMENT_ID, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`404 — ${SITE_TITLE}`} description="Page not found." pageType="collection" robots="noindex" />

    <script
      type="text/partytown"
      src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}
    ></script>
    <script type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', GA_MEASUREMENT_ID);
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main-content" tabindex="-1">
      <section class="not-found">
        <h1 class="not-found-code" aria-hidden="true">404</h1>
        <p class="not-found-label">Page not found</p>
        <p>This page wandered off. We suspect it joined a startup and is now building a competitor.</p>
        <a href="/" class="button">Back to home</a>
      </section>
    </main>
    <Footer />
    <pagefind-modal></pagefind-modal>
  </body>
</html>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
    gap: var(--space-component);
    padding: var(--space-section) var(--space-component);
  }

  .not-found-code {
    font-family: var(--font-mono);
    font-size: clamp(4rem, 12vw, 8rem);
    line-height: 1;
    color: var(--brand-primary);
    margin: 0;
    animation: fade-up 0.6s ease-out;
  }

  .not-found-label {
    font-size: var(--step-1);
    color: var(--text-secondary);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .not-found p {
    max-width: 36ch;
    color: var(--text-secondary);
    margin: 0;
  }

  .button {
    margin-top: var(--space-component);
  }
</style>
