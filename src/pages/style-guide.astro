---
import Layout from '../layouts/BlogPost.astro';
import { SITE_TITLE } from '../consts';
---

<Layout
  title="Style Guide"
  description="Live visual reference of design tokens — colors, typography, spacing, motion, and layout tokens used on this site."
  pubDate={new Date('June 17 2026')}
  pageType="about"
>
  <section>
    <h2>Colors</h2>
    <p>All colors use the OKLCH color space. Toggle <kbd>data-theme</kbd> to see light mode values. Contrast ratios shown are against <code>--bg-main</code> in each theme.</p>

    <h3>Backgrounds</h3>
    <div class="sg-grid">
      <div class="sg-swatch" style="--sg-bg: var(--bg-main)">
        <code>--bg-main</code>
      </div>
      <div class="sg-swatch" style="--sg-bg: var(--bg-surface)">
        <code>--bg-surface</code>
      </div>
      <div class="sg-swatch" style="--sg-bg: var(--bg-surface-elevated)">
        <code>--bg-surface-elevated</code>
      </div>
    </div>

    <h3>Text</h3>
    <div class="sg-grid">
      <div class="sg-swatch sg-swatch--padded" style="--sg-bg: var(--bg-main); --sg-color: var(--text-primary)">
        <code>--text-primary</code>
        <span>15.05:1</span>
      </div>
      <div class="sg-swatch sg-swatch--padded" style="--sg-bg: var(--bg-main); --sg-color: var(--text-secondary)">
        <code>--text-secondary</code>
        <span>4.50:1</span>
      </div>
      <div class="sg-swatch sg-swatch--padded" style="--sg-bg: var(--bg-main); --sg-color: var(--text-muted)">
        <code>--text-muted</code>
        <span>3.28:1</span>
      </div>
    </div>

    <h3>Brand</h3>
    <div class="sg-grid">
      <div class="sg-swatch" style="--sg-bg: var(--brand-primary)">
        <code>--brand-primary</code>
        <span>Amber</span>
      </div>
      <div class="sg-swatch" style="--sg-bg: var(--brand-accent)">
        <code>--brand-accent</code>
        <span>Coral</span>
      </div>
      <div class="sg-swatch" style="--sg-bg: var(--brand-highlight)">
        <code>--brand-highlight</code>
        <span>Chartreuse</span>
      </div>
      <div class="sg-swatch" style="--sg-bg: var(--neutral-anchor)">
        <code>--neutral-anchor</code>
        <span>Slate</span>
      </div>
      <div class="sg-swatch" style="--sg-bg: var(--accent-cold)">
        <code>--accent-cold</code>
        <span>Cerulean</span>
      </div>
    </div>

    <h3>Borders</h3>
    <div class="sg-grid">
      <div class="sg-swatch" style="--sg-bg: var(--border-main)">
        <code>--border-main</code>
      </div>
      <div class="sg-swatch" style="--sg-bg: var(--border-muted)">
        <code>--border-muted</code>
      </div>
    </div>
  </section>

  <section>
    <h2>Typography</h2>

    <h3>Font Families</h3>
    <div class="sg-type-grid">
      <div class="sg-type-card" style="font-family: var(--font-copy)">
        <code>--font-copy</code>
        <p>The quick brown fox jumps over the lazy dog. ABCDEFGHIJKLMNOPQRSTUVWXYZ 0123456789</p>
      </div>
      <div class="sg-type-card" style="font-family: var(--font-headers)">
        <code>--font-headers</code>
        <p>The quick brown fox jumps over the lazy dog. ABCDEFGHIJKLMNOPQRSTUVWXYZ 0123456789</p>
      </div>
      <div class="sg-type-card" style="font-family: var(--font-mono)">
        <code>--font-mono</code>
        <p>The quick brown fox jumps over the lazy dog. ABCDEFGHIJKLMNOPQRSTUVWXYZ 0123456789</p>
      </div>
    </div>

    <h3>Type Scale</h3>
    <div class="sg-scale">
      <div class="sg-scale-item" style="font-size: var(--type-size-h1)">
        <code>--type-size-h1</code>
        <span>32px → 64px</span>
      </div>
      <div class="sg-scale-item" style="font-size: var(--type-size-h2)">
        <code>--type-size-h2</code>
        <span>26px → 45px</span>
      </div>
      <div class="sg-scale-item" style="font-size: var(--type-size-h3)">
        <code>--type-size-h3</code>
        <span>22px → 32px</span>
      </div>
      <div class="sg-scale-item" style="font-size: var(--type-size-h4)">
        <code>--type-size-h4</code>
        <span>18px → 24px</span>
      </div>
      <div class="sg-scale-item" style="font-size: var(--type-size-h5)">
        <code>--type-size-h5</code>
        <span>16px → 19px</span>
      </div>
      <div class="sg-scale-item" style="font-size: var(--type-size-body)">
        <code>--type-size-body</code>
        <span>16px → 20px</span>
      </div>
      <div class="sg-scale-item" style="font-size: var(--type-size-small)">
        <code>--type-size-small</code>
        <span>13px → 15px</span>
      </div>
    </div>
  </section>

  <section>
    <h2>Spacing Scale</h2>
    <p>Based on <code>--rhythm: calc(var(--line-height-body) * 1rem)</code> (<code>≈ 1.65rem</code>). Each bar is rendered at the token's computed width.</p>
    <div class="sg-spacing">
      <div class="sg-spacing-item">
        <span class="sg-bar" style="width: var(--space-xs)"></span>
        <code>--space-xs</code>
        <span class="sg-label">0.5× rhythm</span>
      </div>
      <div class="sg-spacing-item">
        <span class="sg-bar" style="width: var(--space-sm)"></span>
        <code>--space-sm</code>
        <span class="sg-label">0.75× rhythm</span>
      </div>
      <div class="sg-spacing-item">
        <span class="sg-bar" style="width: var(--space-md)"></span>
        <code>--space-md</code>
        <span class="sg-label">1× rhythm</span>
      </div>
      <div class="sg-spacing-item">
        <span class="sg-bar" style="width: var(--space-lg)"></span>
        <code>--space-lg</code>
        <span class="sg-label">1.5× rhythm</span>
      </div>
      <div class="sg-spacing-item">
        <span class="sg-bar" style="width: var(--space-xl)"></span>
        <code>--space-xl</code>
        <span class="sg-label">2× rhythm</span>
      </div>
    </div>
  </section>

  <section>
    <h2>Borders & Radii</h2>
    <div class="sg-border-row">
      <div class="sg-border-sample" style="border-radius: var(--radius-sm); background: var(--bg-surface-elevated)">
        <code>--radius-sm</code>
        <span>4px</span>
      </div>
      <div class="sg-border-sample" style="border-radius: var(--radius-md); background: var(--bg-surface-elevated)">
        <code>--radius-md</code>
        <span>8px</span>
      </div>
      <div class="sg-border-sample" style="border-radius: var(--radius-lg); background: var(--bg-surface-elevated)">
        <code>--radius-lg</code>
        <span>12px</span>
      </div>
      <div class="sg-border-sample" style="border-width: var(--size-border-pixel); border-style: solid; border-color: var(--border-main)">
        <code>--size-border-pixel</code>
        <span>2px</span>
      </div>
      <div class="sg-border-sample" style="border-width: var(--size-border-thick); border-style: solid; border-color: var(--border-main)">
        <code>--size-border-thick</code>
        <span>4px</span>
      </div>
    </div>
  </section>

  <section>
    <h2>Motion</h2>
    <p>Hover or tap the bars below to see each transition duration. The bar shrinks from 100% to 25% width.</p>
    <div class="sg-motion-row">
      <div class="sg-motion-sample">
        <code>--transition-fast</code>
        <div class="sg-motion-bar sg-motion-fast"></div>
        <span>0.15s</span>
      </div>
      <div class="sg-motion-sample">
        <code>--transition-normal</code>
        <div class="sg-motion-bar sg-motion-normal"></div>
        <span>0.25s</span>
      </div>
      <div class="sg-motion-sample">
        <code>--transition-slow</code>
        <div class="sg-motion-bar sg-motion-slow"></div>
        <span>0.40s</span>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* --- Color Groups (flattened: each group is its own grid) --- */
  .sg-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: var(--space-inline);
    margin-bottom: var(--space-component-lg);
  }

  .sg-grid .sg-swatch--padded {
    min-height: 100px;
    justify-content: flex-end;
  }

  .sg-swatch {
    background: var(--sg-bg, var(--bg-surface));
    color: var(--sg-color, var(--text-primary));
    padding: var(--space-component);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-muted);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .sg-swatch code {
    font-size: var(--type-size-small);
    color: var(--sg-color, var(--text-primary));
  }

  .sg-swatch span {
    font-size: var(--type-size-small);
    font-family: var(--font-mono);
    color: var(--text-muted);
  }

  /* --- Typography --- */
  .sg-type-grid {
    display: grid;
    gap: var(--space-component);
    margin-bottom: var(--space-section);
  }

  .sg-type-card {
    background: var(--bg-surface);
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-md);
    padding: var(--space-component);
    line-height: 1.5;
  }

  .sg-type-card code {
    font-size: var(--type-size-small);
    font-family: var(--font-mono);
    color: var(--text-muted);
    margin-bottom: var(--space-inline);
    display: block;
  }

  .sg-type-card p {
    margin: 0;
  }

  /* --- Type Scale --- */
  .sg-scale {
    display: grid;
    gap: var(--space-component);
  }

  .sg-scale-item {
    display: flex;
    align-items: baseline;
    gap: var(--space-component);
    font-family: var(--font-headers);
    font-weight: 700;
    line-height: 1.2;
    padding: var(--space-inline) 0;
    border-bottom: 1px solid var(--border-muted);
  }

  .sg-scale-item code {
    font-size: var(--type-size-small);
    font-family: var(--font-mono);
    font-weight: 400;
    color: var(--brand-primary);
    flex-shrink: 0;
  }

  .sg-scale-item span {
    font-size: var(--type-size-small);
    font-weight: 400;
    color: var(--text-muted);
    font-family: var(--font-copy);
    flex-shrink: 0;
  }

  /* --- Spacing --- */
  .sg-spacing {
    display: grid;
    gap: var(--space-component);
  }

  .sg-spacing-item {
    display: flex;
    align-items: center;
    gap: var(--space-inline);
  }

  .sg-spacing-item code {
    font-size: var(--type-size-small);
    min-width: 7.5em;
  }

  .sg-bar {
    display: block;
    height: 1rem;
    background: var(--brand-primary);
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }

  .sg-label {
    font-size: var(--type-size-small);
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  /* --- Borders --- */
  .sg-border-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-component);
  }

  .sg-border-sample {
    width: 130px;
    height: 90px;
    background: var(--bg-surface);
    border: var(--size-border-pixel) solid var(--border-main);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-xs);
    text-align: center;
  }

  .sg-border-sample code {
    font-size: var(--type-size-small);
  }

  .sg-border-sample span {
    font-size: var(--type-size-small);
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  /* --- Motion --- */
  .sg-motion-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-component);
  }

  .sg-motion-sample {
    flex: 1;
    min-width: 160px;
    display: flex;
    flex-direction: column;
    gap: var(--space-inline);
  }

  .sg-motion-sample code {
    font-size: var(--type-size-small);
  }

  .sg-motion-bar {
    height: 1.5rem;
    width: 100%;
    background: var(--brand-primary);
    border-radius: var(--radius-sm);
  }

  .sg-motion-fast { transition: width var(--transition-fast); }
  .sg-motion-normal { transition: width var(--transition-normal); }
  .sg-motion-slow { transition: width var(--transition-slow); }

  .sg-motion-sample:hover .sg-motion-bar,
  .sg-motion-row:hover .sg-motion-bar {
    width: 25%;
  }

  .sg-motion-sample span {
    font-size: var(--type-size-small);
    color: var(--text-muted);
    font-family: var(--font-mono);
  }
</style>
