#!/usr/bin/env bash
set -euo pipefail

MODEL="flux_2_klein_4b_q6p.ckpt"
DRAW_THINGS="draw-things-cli"
PROMPT=""
NEGATIVE=""
OUTPUT=""
WIDTH="1216"
HEIGHT="640"
STEPS=""
SEED=""
OG_WIDTH="1200"
OG_HEIGHT="630"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --model|--low-ram) shift ;;
    --prompt) PROMPT="$2"; shift 2 ;;
    --negative-prompt) NEGATIVE="$2"; shift 2 ;;
    --output) OUTPUT="$2"; shift 2 ;;
    --width) WIDTH="$2"; shift 2 ;;
    --height) HEIGHT="$2"; shift 2 ;;
    --steps) STEPS="$2"; shift 2 ;;
    --seed) SEED="$2"; shift 2 ;;
    -h|--help)
      echo "Usage: $(basename "$0") --prompt TEXT --output PATH [options]"
      echo "Model: $MODEL via draw-things-cli + cwebp conversion"
      exit 0
      ;;
    *) echo "Unknown: $1"; exit 1 ;;
  esac
done

if [[ -z "$PROMPT" || -z "$OUTPUT" ]]; then
  echo "Error: --prompt and --output are required" >&2
  exit 1
fi

GEN_OUTPUT="$OUTPUT"
if [[ "$OUTPUT" == *.webp ]]; then
  GEN_OUTPUT="${OUTPUT%.webp}.png"
fi

DT_ARGS=(
  --model "$MODEL"
  --models-dir "/Volumes/BACKUP/dt"
  --prompt "$PROMPT"
  --output "$GEN_OUTPUT"
  --disable-preview
)

[[ -n "$WIDTH" ]] && DT_ARGS+=(--width "$WIDTH")
[[ -n "$HEIGHT" ]] && DT_ARGS+=(--height "$HEIGHT")
[[ -n "$STEPS" ]] && DT_ARGS+=(--steps "$STEPS")
[[ -n "$SEED" ]] && DT_ARGS+=(-s "$SEED")
[[ -n "$NEGATIVE" ]] && DT_ARGS+=(--negative-prompt "$NEGATIVE")

echo "  draw-things-cli generate ..."
"$DRAW_THINGS" generate "${DT_ARGS[@]}"

# Crop to OG size (1200×630) using a center crop
CROPPED="${GEN_OUTPUT%.png}-cropped.png"
if ! command -v sips &>/dev/null; then
  echo "  sips not found – skipping crop" >&2
  CROPPED="$GEN_OUTPUT"
else
  echo "  Cropping to ${OG_WIDTH}x${OG_HEIGHT}..."
  sips --cropToHeightWidth "$OG_HEIGHT" "$OG_WIDTH" "$GEN_OUTPUT" --out "$CROPPED" &>/dev/null
fi

if [[ "$CROPPED" != "$OUTPUT" ]]; then
  if command -v cwebp &>/dev/null; then
    echo "  Converting to WebP..."
    cwebp -quiet -q 85 "$CROPPED" -o "$OUTPUT"
    rm -f "$GEN_OUTPUT" "$CROPPED"
  else
    echo "  cwebp not found, keeping PNG at $CROPPED"
    if [[ "$CROPPED" != "$GEN_OUTPUT" ]]; then
      mv "$CROPPED" "${OUTPUT%.webp}.png"
      rm -f "$GEN_OUTPUT"
    fi
  fi
fi
